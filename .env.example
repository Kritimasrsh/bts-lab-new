# Postgres connection string used by Prisma.
# Local example:   postgresql://postgres:postgres@localhost:5432/bts_lab?schema=public
# Neon/Supabase:   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bts_lab?schema=public"

# --- Auth.js ---
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Google OAuth — from Google Cloud Console → APIs & Services → Credentials.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Leave blank to hide/disable the Google button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
