generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?
  role          Role            @default(CUSTOMER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  requests      RepairRequest[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// A phone/device manufacturer (admin-managed).
model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  models    Model[]

  @@index([active, order])
}

/// A specific device model (admin-managed), grouped under a series for display.
/// e.g. brand=Apple, series="iPhone 11", name="iPhone 11 Pro Max".
model Model {
  id        String          @id @default(cuid())
  name      String
  slug      String
  series    String?
  image     String?
  order     Int             @default(0)
  active    Boolean         @default(true)
  brandId   String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  brand     Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  requests  RepairRequest[]

  @@unique([brandId, slug])
  @@index([brandId, active, order])
}

/// A group of problems shown as a heading (Display, Audio, Body, …).
model ProblemCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  problems  Problem[]

  @@index([order])
}

/// A single selectable problem (global — same list for every model).
model Problem {
  id         String                 @id @default(cuid())
  name       String
  slug       String                 @unique
  order      Int                    @default(0)
  active     Boolean                @default(true)
  categoryId String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  category   ProblemCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  onRequests RepairRequestProblem[]

  @@unique([categoryId, name])
  @@index([categoryId, active, order])
}

/// A repair enquiry submitted from the public flow.
model RepairRequest {
  id            String                 @id @default(cuid())
  modelId       String
  customNote    String?
  customerName  String?
  customerPhone String?
  status        RepairStatus           @default(NEW)
  userId        String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  model         Model                  @relation(fields: [modelId], references: [id])
  user          User?                  @relation(fields: [userId], references: [id])
  problems      RepairRequestProblem[]

  @@index([status, createdAt])
  @@index([userId])
}

/// Join table: which problems a given request selected.
model RepairRequestProblem {
  id        String        @id @default(cuid())
  requestId String
  problemId String
  problem   Problem       @relation(fields: [problemId], references: [id])
  request   RepairRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, problemId])
}

model GoogleReview {
  id        String   @id
  author    String
  rating    Int      @default(5)
  text      String
  service   String?
  avatarUrl String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([published, order])
}

model Testimonial {
  id        String   @id
  author    String
  role      String?
  rating    Int      @default(5)
  quote     String
  featured  Boolean  @default(false)
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([published, order])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum RepairStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
